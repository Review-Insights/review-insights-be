{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Npgsql": "Warning",
        "Minio": "Warning",
        "RabbitMQ.Client": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "ReviewInsights.Api"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "BucketName": "review-insights-uploads",
    "UseSSL": false
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "ExchangeName": "review-insights.exchange",
    "AnalyzeReviewsQueue": "review-insights.analyze.reviews",
    "AnalyzeReviewsRoutingKey": "analyze.reviews",
    "GenerateReportQueue": "review-insights.generate.report",
    "GenerateReportRoutingKey": "generate.report",
    "UploadResultsQueue": "review-insights.uploads.results",
    "UploadResultsRoutingKey": "uploads.results",
    "UploadErrorQueue": "review-insights.uploads.errors",
    "UploadErrorRoutingKey": "uploads.errors",
    "ReportResultQueue": "review-insights.reports.result",
    "ReportResultRoutingKey": "reports.result",
    "ReportErrorQueue": "review-insights.reports.errors",
    "ReportErrorRoutingKey": "reports.errors",
    "BatchSize": 200
  },
  "ReportLimits": {
    "MaxReviewsPerReport": 5000
  }
}
