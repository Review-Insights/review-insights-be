{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "BucketName": "review-insights-uploads",
    "UseSSL": false
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "ExchangeName": "review-insights.exchange",
    "AnalyzeReviewsQueue": "review-insights.analyze.reviews",
    "AnalyzeReviewsRoutingKey": "analyze.reviews",
    "GenerateReportQueue": "review-insights.generate.report",
    "GenerateReportRoutingKey": "generate.report",
    "BatchSize": 50
  },
  "ReportLimits": {
    "MaxReviewsPerReport": 5000
  }
}
